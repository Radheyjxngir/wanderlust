<% layout('layout/boilerplate') %>

<div class="row mt-3 form-page">
    <div class="col-12 col-lg-8 offset-lg-2">
        <br><br>
        <h3 class="mb-3">Create a New Listing</h3>
        
        <form action="/listings" method="POST" novalidate class="needs-validation listing-upload-form" enctype="multipart/form-data">
            
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="listing[title]" id="title" placeholder="Catchy title" class="form-control" required>
                <div class="invalid-feedback">Tilte is required</div>
                <div class="valid-feedback"></div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" id="description" class="form-control" placeholder="Describe your place..." rows="4" required></textarea>
                <div class="invalid-feedback">Please Describe</div>
            </div>

        

            <div class="mb-3">
                <label for="images" class="form-label">Upload listing photos</label>
                <input type="file" name="listing[images]" id="images" class="form-control listing-images-input" accept="image/*" multiple data-preview-target="listing-upload-preview">
                <div class="form-text">1 se 6 photos upload kar sakte ho.</div>
                <div id="listing-upload-preview" class="upload-preview-grid mt-3"></div>
            </div>

            <div class="upload-progress-card d-none mb-3" data-upload-progress>
                <div class="upload-progress-head">
                    <strong>Uploading photos...</strong>
                    <span data-upload-text>0%</span>
                </div>
                <div class="upload-progress-track">
                    <div class="upload-progress-bar" data-upload-bar></div>
                </div>
            </div>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group has-validation">
                        <span class="input-group-text">₹</span>
                        <input type="number" name="listing[price]" id="price" placeholder="1200" class="form-control" required>
                        <div class="invalid-feedback">Please Enter the price</div>
                    </div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" id="location" placeholder="Jaipur, Rajasthan" class="form-control" required>
                    <div class="invalid-feedback">Please enter the location</div>
                </div>
            </div>

            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listing[country]" id="country" placeholder="India" class="form-control" required>
                <div class="invalid-feedback">Countary name is required</div>
            </div>

            <button type="submit" class="btn btn-dark add-btn mt-3 mb-5">Add Listing</button>
        </form>
    </div>
</div>
