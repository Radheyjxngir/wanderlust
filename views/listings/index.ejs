<% layout('layout/boilerplate') %> 
<%= success %>
<div class="container mt-3">
    <h3 class="mb-3">All Listings</h3>
    
    <a href="/listings/new" class="btn btn-dark mb-4">Add New Listing</a>

    <div class="row row-cols-xxl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
        <% for(let listing of allListings) { %>
            <div class="col">
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card h-100 listing-card">
                        <img src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" class="card-img-top" alt="listing image">
                        
                        <div class="card-body px-1">
                            <p class="card-text">
                                <b><%= listing.title %></b> <br>
                                <span class="text-muted"><%= listing.location %>, <%= listing.country %></span> <br>
    <b>&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "Price not available" %></b> / night
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        <% } %>
    </div>
</div>
