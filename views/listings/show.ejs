<% layout('layout/boilerplate') %>

<div class="container mt-3">
    <div class="row">
        <div class="col-12 col-md-8 offset-md-2">
            <h3 class="fw-bold mt-3"><%= listing.title %></h3>
            <div class="card show-card listing-card border-0">
                <img 
                    src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" 
                    class="card-img-top show-img" 
                    alt="listing_image"
                >
                <div class="card-body px-1">
                    <p class="card-text text-muted mb-2">Hosted by Radheyshyam</p>
                    <p class="card-text"><%= listing.description %></p>
                    <p class="card-text fw-bold fs-5">
                        &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %> / night
                    </p>
                    <p class="card-text">
                        <i class="fa-solid fa-location-dot me-2 text-danger"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <hr />

    <div class="row mb-5">
        <div class="col-12 col-md-8 offset-md-2">
            <div class="d-flex gap-3 mb-4">
                <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark edit-btn px-4 py-2">Edit</a>
                <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                    <button class="btn btn-danger delete-btn px-4 py-2">Delete</button>
                </form>
            </div>
            
            <hr />

            <h4>Leave a Review</h4>
            <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                <div class="mb-3 mt-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" name="review[rating]" id="rating" min="1" max="5" value="3" class="form-range" step="1" required>
                </div>

                <div class="mb-3">
                    <label for="comment" class="form-label">Comment</label>
                    <textarea class="form-control" id="comment" name="review[comment]" rows="4" required></textarea>
                    <div class="invalid-feedback">Please add some comments for review</div>
                </div>

                <button type="submit" class="btn btn-outline-dark">Submit Review</button>
            </form>

            <hr>

            <% if(listing.reviews.length > 0) { %>
                <div class="row">
                    <p><b>All Reviews</b></p>
                    <% for(let review of listing.reviews) { %>
                        <div class="card col-5 ms-3 mb-3 border">
                            <div class="card-body p-2">
                                <h6 class="card-title fw-bold">Anonymous</h6>
                                <p class="card-text mb-1"><%= review.comment %></p>
                                <p class="card-text text-warning mb-2">
                                    <% for(let i=0; i<review.rating; i++) { %>
                                        <i class="fa-solid fa-star"></i>
                                    <% } %>
                                    <% for(let i=review.rating; i<5; i++) { %>
                                        <i class="fa-regular fa-star"></i>
                                    <% } %>
                                </p>
                                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                                    <button class="btn btn-sm btn-dark">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } %>
        </div>
    </div>
</div>
