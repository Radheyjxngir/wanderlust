<% layout('layout/boilerplate') %>

<div class="row mt-3 form-page">
    <div class="col-12 col-lg-8 offset-lg-2">
        <br><br>
        <h3 class="mb-3">Edit your Listing</h3>
        
        <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" class="needs-validation listing-upload-form" novalidate enctype="multipart/form-data">
            
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="listing[title]" value="<%= listing.title %>" class="form-control" placeholder="Enter a catchy title" required>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" class="form-control" rows="5" required><%= listing.description %></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label d-block">Current Photos</label>
                <div class="upload-preview-grid existing-upload-grid mb-3">
                    <% for (let imageUrl of (listing.galleryImageUrls || [listing.imageEditUrl || listing.imageFallbackUrl]).slice(0, 6)) { %>
                        <img
                            src="<%= imageUrl %>"
                            alt="current listing image"
                            class="edit-preview-img"
                            loading="lazy"
                            decoding="async"
                            onerror="this.onerror=null;this.src='<%= listing.imageFallbackUrl || 'https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=800&q=60' %>';"
                        >
                    <% } %>
                </div>
                <label for="images" class="form-label">Replace Photos</label>
                <input type="file" name="listing[images]" id="images" class="form-control listing-images-input" accept="image/*" multiple data-preview-target="listing-upload-preview">
                <div class="form-text">Nayi 1 se 6 photos upload karoge to purani gallery replace ho jayegi.</div>
                <div id="listing-upload-preview" class="upload-preview-grid mt-3"></div>
            </div>

            <div class="upload-progress-card d-none mb-3" data-upload-progress>
                <div class="upload-progress-head">
                    <strong>Uploading photos...</strong>
                    <span data-upload-text>0%</span>
                </div>
                <div class="upload-progress-track">
                    <div class="upload-progress-bar" data-upload-bar></div>
                </div>
            </div>

            <div class="row">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label">Price</label>
                    <div class="input-group">
                        <span class="input-group-text">₹</span>
                        <input type="number" name="listing[price]" value="<%= listing.price %>" class="form-control" required>
                    </div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="location" class="form-label">Location</label>
                    <input type="text" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="country" class="form-label">Country</label>
                <input type="text" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
            </div>

            <div class="mb-5 d-flex flex-wrap gap-2">
                <button type="submit" class="btn btn-dark edit-btn mt-3">Save Changes</button>
                <a href="/listings/<%= listing._id %>" class="btn btn-outline-danger mt-3 ms-0" style="border-radius: 0.5rem;">Cancel</a>
            </div>
        </form>
    </div>
</div>
