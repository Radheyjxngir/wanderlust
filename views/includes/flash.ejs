<% if (typeof success !== "undefined" && success && success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert">
        <%= success[0] %>
        <button class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert" type="button" data-bs-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>   
    </div>
<% } %>

<% if (typeof error !== "undefined" && error && error.length) { %>
    <div class="alert alert-danger" role="alert">
        <%= error[0] %>
    </div>
<% } %>
